#!/usr/bin/env python3
"""bd-all: Aggregate beads across all Gas Town rigs.

Usage:
    bd-all              # all beads, all rigs
    bd-all --open       # open/in_progress/blocked only
    bd-all --ready      # unblocked, ready to work
    bd-all --summary    # one-line-per-rig counts
    bd-all --table      # human-readable table
"""

import json
import os
import subprocess
import sys
from pathlib import Path

GT_ROOT = Path(os.environ.get("GT_ROOT", os.path.expanduser("~/gt")))
FILTER = sys.argv[1] if len(sys.argv) > 1 else None


def find_beads_stores():
    """Find all directories where bd list can run."""
    stores = []
    for entry in sorted(GT_ROOT.iterdir()):
        if not entry.is_dir() or entry.name.startswith("."):
            continue
        if entry.name in ("bin", "tmp"):
            continue
        # Check rig-level .beads
        if (entry / ".beads" / "metadata.json").exists():
            stores.append((entry.name, entry))
        elif (entry / "mayor" / "rig" / ".beads" / "metadata.json").exists():
            stores.append((entry.name, entry / "mayor" / "rig"))
    return stores


def list_beads(rig_name, path):
    """Run bd list --json in a directory and return tagged beads."""
    try:
        result = subprocess.run(
            ["bd", "list", "--json"],
            cwd=str(path),
            capture_output=True,
            text=True,
            timeout=10,
        )
        if result.returncode != 0:
            return []
        # bd may print warnings to stderr; stdout has the JSON
        raw = result.stdout.strip()
        if not raw or raw == "[]":
            return []
        beads = json.loads(raw)
        for b in beads:
            b["rig"] = rig_name
        return beads
    except (json.JSONDecodeError, subprocess.TimeoutExpired, Exception):
        return []


def main():
    stores = find_beads_stores()
    all_beads = []
    for rig_name, path in stores:
        all_beads.extend(list_beads(rig_name, path))

    # Sort by priority then rig
    all_beads.sort(key=lambda b: (b.get("priority", 9), b.get("rig", "")))

    if FILTER == "--summary":
        by_rig = {}
        for b in all_beads:
            rig = b.get("rig", "unknown")
            by_rig.setdefault(rig, []).append(b)
        for rig in sorted(by_rig):
            items = by_rig[rig]
            statuses = {}
            for b in items:
                s = b.get("status", "unknown")
                statuses[s] = statuses.get(s, 0) + 1
            status_str = ", ".join(f"{v} {k}" for k, v in sorted(statuses.items()))
            print(f"  {rig}: {len(items)} beads ({status_str})")

    elif FILTER == "--open":
        filtered = [b for b in all_beads if b.get("status") in ("open", "in_progress", "blocked")]
        print(json.dumps(filtered, indent=2))

    elif FILTER == "--ready":
        filtered = [b for b in all_beads if b.get("status") in ("open", "in_progress")]
        print(json.dumps(filtered, indent=2))

    elif FILTER == "--table":
        active = [b for b in all_beads if b.get("status") in ("open", "in_progress", "blocked")]
        if not active:
            print("  No active beads.")
            return
        # Group by rig
        by_rig = {}
        for b in active:
            by_rig.setdefault(b.get("rig", "?"), []).append(b)
        for rig in sorted(by_rig):
            print(f"\n  [{rig}]")
            for b in sorted(by_rig[rig], key=lambda x: x.get("priority", 9)):
                status = b.get("status", "?")
                marker = {"open": " ", "in_progress": ">", "blocked": "!"}
                icon = marker.get(status, "?")
                p = b.get("priority", "?")
                bead_id = b.get("id", "?")
                title = b.get("title", "?")[:60]
                print(f"    {icon} P{p} {bead_id} {title}")

    else:
        print(json.dumps(all_beads, indent=2))


if __name__ == "__main__":
    main()
